# Copie este arquivo para sentinel.env no mesmo diretorio do sentinel.exe.
# O setup.bat pode gerar este arquivo automaticamente.

SENTINEL_ENDPOINT=https://log-sentinel.seudominio.com/api/v1/events
SENTINEL_API_TOKEN=troque-este-token
SENTINEL_INTERVAL_MINUTES=60
# Opcional: se vazio, o agente usa ./data/buffer.db ao lado do executavel.
# SENTINEL_BUFFER_PATH=C:\Aiknow\acc_log_sentinel\data\buffer.db
